@page
@model FlorenBooksWeb.Pages.SuperAdmin.DashboardModel
@{
    ViewData["Title"] = "Super Admin";
}

<h1 class="h3">Super Admin</h1>
<p class="text-muted">Administrare globala FlorenBooks.</p>

<div class="row g-3">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Carti</div><div class="h3">@Model.Stats?.Books</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Utilizatori</div><div class="h3">@Model.Stats?.Users</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Imprumuturi active</div><div class="h3">@Model.Stats?.ActiveBorrows</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Achizitii</div><div class="h3">@Model.Stats?.Purchases</div></div></div>
</div>

<div class="mt-4">
    <a class="btn btn-primary" asp-page="/SuperAdmin/Users">Administreaza utilizatorii</a>
    <a class="btn btn-outline-primary" asp-page="/LibraryAdmin/Books">Administreaza cartile</a>
    <a class="btn btn-outline-primary" asp-page="/BorrowAdmin/Borrowed">Administreaza imprumuturile</a>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-6">
        <div class="border rounded bg-white p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Imprumuturi recente</h2>
                <a class="btn btn-sm btn-outline-primary" asp-page="/BorrowAdmin/Borrowed">Vezi tot</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Utilizator</th>
                            <th>Carte</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentBorrows.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-muted">Nu exista imprumuturi inregistrate.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var borrow in Model.RecentBorrows)
                            {
                                <tr>
                                    <td>@borrow.UserEmail</td>
                                    <td>@borrow.Titlu</td>
                                    <td>@(borrow.ReturnDate is null ? "Activa" : "Returnata")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="border rounded bg-white p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Achizitii recente</h2>
                <a class="btn btn-sm btn-outline-primary" asp-page="/LibraryAdmin/Purchases">Vezi tot</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Utilizator</th>
                            <th>Carte</th>
                            <th>Pret</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentPurchases.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-muted">Nu exista achizitii inregistrate.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var purchase in Model.RecentPurchases)
                            {
                                <tr>
                                    <td>@purchase.UserEmail</td>
                                    <td>@purchase.Titlu</td>
                                    <td>@(purchase.Pret?.ToString("0.00") ?? "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
