<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlorenBooks</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FlorenBooksWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">FlorenBooks</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Catalog/Index">Catalog</a>
                            </li>
                        }
                        @if (User.IsInRole("superAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/SuperAdmin/Dashboard">Super Admin</a>
                            </li>
                        }
                        @if (User.IsInRole("libraryAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/LibraryAdmin/Dashboard">Library Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/LibraryAdmin/Books">Carti</a>
                            </li>
                        }
                        @if (User.IsInRole("borrowAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/BorrowAdmin/Dashboard">Borrow Admin</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/BorrowAdmin/Borrowed">Imprumuturi</a>
                            </li>
                        }
                        @if (User.IsInRole("user"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/User/Dashboard">Utilizator</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/User/MyBooks">Cartile mele</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="navbar-text me-3">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Account/Logout">
                                    <button type="submit" class="btn btn-link nav-link text-dark">Iesire</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Account/Login">Intrare</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - FlorenBooks
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
