@page
@model FlorenBooksWeb.Pages.LibraryAdmin.PurchasesModel
@{
    ViewData["Title"] = "Achizitii";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Achizitii</h1>
        <p class="text-muted mb-0">Raport carti cumparate de utilizatori.</p>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-sm-8 col-md-6">
        <input asp-for="Search" class="form-control" placeholder="Cauta dupa email, titlu sau autor" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Cauta</button>
    </div>
    <div class="col-auto">
        <button type="submit" asp-page-handler="Export" class="btn btn-outline-secondary">Export CSV</button>
    </div>
</form>

<div class="border rounded p-3 mb-3 bg-white">
    <div class="text-muted">Total achizitii afisate</div>
    <div class="h4 mb-0">@Model.TotalAmount.ToString("0.00")</div>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Utilizator</th>
                <th>Carte</th>
                <th>Autor</th>
                <th>Pret</th>
                <th>Data achizitie</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var purchase in Model.Purchases)
            {
                <tr>
                    <td>@purchase.UserEmail</td>
                    <td>@purchase.Titlu</td>
                    <td>@purchase.Autor</td>
                    <td>@(purchase.Pret?.ToString("0.00") ?? "-")</td>
                    <td>@purchase.PurchaseDate?.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
